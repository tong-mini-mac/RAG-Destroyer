        <mxCell id="llm" value="LLM Provider Layer&#xa;Google / OpenAI / Anthropic&#xa;core/LLMProviders.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="650" y="470" width="320" height="95" as="geometry" />
