        </mxCell>

        <mxCell id="identity" value="Identity Context&#xa;(role + active department)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="1">
          <mxGeometry x="350" y="140" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="policy" value="Policy Gate&#xa;RBAC + audience + per-file rules&#xa;core/Utils.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="130" width="300" height="100" as="geometry" />
        </mxCell>

        <mxCell id="orchestrator" value="Orchestrator&#xa;core/Orchestrator.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
